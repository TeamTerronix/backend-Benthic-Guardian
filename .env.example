# Backend environment variables (copy to .env for local use)
# If you use uvicorn directly, run with:
#   uvicorn main:app --env-file .env
#
# Set DATABASE_URL before running provision_prototype.py or the API, or SQLite ./sliot.db is used.

# --- Supabase (recommended for production) ---
# Supabase → Project Settings → Database → Connection string → URI
# Use "Session pooler" (port 5432) for long-running API, or "Transaction" (port 6543).
# If your password has special characters (@, #, etc.), URL-encode them.
# Example (replace placeholders):
# DATABASE_URL=postgresql+psycopg://postgres.[project-ref]:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
#
# Migrate existing SQLite data:
#   python migrate_to_supabase.py --source sqlite:///./sliot.db

# Local PostgreSQL (Docker compose)
DATABASE_URL=postgresql+psycopg://sliot_user:change_me@localhost:5432/sliot

# Local SQLite (offline dev only)
# DATABASE_URL=sqlite:///./sliot.db

# JWT / Auth
SECRET_KEY=replace-with-a-long-random-secret
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Optional: override PINN model directory (default: ./model in backend repo, or ../model in monorepo)
# MODEL_DIR=/app/model
# Set these in Render → Environment (do not commit real secrets):
#   DATABASE_URL=postgresql+psycopg://postgres.[ref]:[ENCODED-PASSWORD]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres
#   SECRET_KEY=<long-random-string>
#   CORS_ORIGINS=https://your-dashboard.vercel.app
#   CORS_ORIGIN_REGEX=https://.*\.vercel\.app
# Render injects PORT automatically; docker-entrypoint.sh and start.sh use it.

# Optional: comma-separated extra browser origins (localhost is already allowed by default)
# CORS_ORIGINS=https://your-app.vercel.app
# Optional: regex for preview deploys (e.g. all *.vercel.app)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app
